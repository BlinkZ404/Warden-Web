# ─────────────────────────────────────────────────────────────────────────────
# Warden configuration
#
# Copy to `.env` for local dev. The repo ships ready to run in `simulation`
# mode with the bundled Docker Postgres; no external accounts or API keys
# required. To go live, set WARDEN_MODE=live and fill in the secrets below
# (see docs/operations/go-live.md).
# ─────────────────────────────────────────────────────────────────────────────

# `simulation` (default): Sentry/Vercel/push delivery and the LLM agents are
#   simulated; the deterministic verification gate (tests + error-gone check)
#   stays REAL. Runs fully offline.
# `live`: real adapters are used wherever the matching secret is present.
WARDEN_MODE=simulation

# Postgres. Local dev points at the bundled Docker container (host port 5433).
# In production this is the Amazon Aurora PostgreSQL (Serverless v2) endpoint.
DATABASE_URL=postgres://warden:warden@localhost:5433/warden

# ── live-mode secrets (leave blank in simulation) ───────────────────────────
#
# AGENTS: any OpenAI-compatible provider (DeepSeek, GLM/Z.ai/Zhipu, OpenAI,
# OpenRouter, a local Ollama, etc.). These are PREFERRED over the native
# ANTHROPIC/OPENAI keys below. AGENT_* is the default for every agent;
# FIXER_*/REVIEWER_*/INVESTIGATOR_* override it (run the cross-check on two
# different model families). Requires WARDEN_MODE=live.
#
#   Cheapest: everything on GLM's FREE tier (glm-4.5-flash is free, no card):
#     AGENT_BASE_URL=https://api.z.ai/api/paas/v4
#     AGENT_API_KEY=<your z.ai key>
#     AGENT_MODEL=glm-4.5-flash
#
#   Two model families for the cross-check (Fixer=DeepSeek ~pennies, Reviewer=GLM free):
#     FIXER_BASE_URL=https://api.deepseek.com/v1
#     FIXER_API_KEY=<deepseek key>
#     FIXER_MODEL=deepseek-chat
#     REVIEWER_BASE_URL=https://api.z.ai/api/paas/v4
#     REVIEWER_API_KEY=<z.ai key>
#     REVIEWER_MODEL=glm-4.5-flash
AGENT_BASE_URL=
AGENT_API_KEY=
AGENT_MODEL=

# REVIEWER PANEL (PLAN §5.4): 1 Fixer + 1–3 Reviewers. More reviewers from
# DIFFERENT model families = a stronger decorrelated cross-check.
#   - Easiest: replicate the default reviewer provider N times (1–3):
#       REVIEW_PANEL_SIZE=3
#   - Or pick distinct providers per slot (run the cross-check on 3 families):
#       REVIEWER_1_BASE_URL=https://api.z.ai/api/paas/v4
#       REVIEWER_1_API_KEY=<z.ai key>
#       REVIEWER_1_MODEL=glm-4.5-flash
#       REVIEWER_2_BASE_URL=https://api.deepseek.com/v1
#       REVIEWER_2_API_KEY=<deepseek key>
#       REVIEWER_2_MODEL=deepseek-chat
#       # REVIEWER_3_* … (up to 3)
# Consensus: proceed only if all reviewers approve (default). Relax to a quorum:
#   REVIEW_APPROVALS_REQUIRED=2
REVIEW_PANEL_SIZE=
REVIEW_APPROVALS_REQUIRED=

# Native providers (used only if the OpenAI-compatible vars above are unset):
# Fixer/Investigator via the Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Reviewer via native OpenAI (chat-completions model; not a Codex/responses model)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Embeddings for incident memory (optional; falls back to deterministic local)
EMBEDDING_API_KEY=

# Sentry webhook signature verification
SENTRY_CLIENT_SECRET=

# Vercel deploy/rollback
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_REPO_ID=

# Optional shared secret to gate approve/rollback/orchestrator-tick routes.
# When set, requests must send `Authorization: Bearer <secret>`.
WARDEN_API_SECRET=

# Web push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:founder@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# The repo Warden watches/fixes (the customer's app).
# In simulation this defaults to the bundled ./sample-app.
TARGET_REPO_PATH=./sample-app
