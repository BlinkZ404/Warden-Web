# ─────────────────────────────────────────────────────────────────────────────
# Warden configuration
#
# Copy to `.env` for local dev. The repo ships ready to run in `simulation`
# mode with the bundled Docker Postgres; no external accounts or API keys
# required. To go live, set WARDEN_MODE=live and fill in the secrets below
# (see docs/operations/go-live.md).
#
# The runtime reads the dashboard-saved settings BEFORE process.env, so most
# operator settings (delivery mode, autopilot, billing, guardrails, boot
# commands, per-role model assignments, Slack) are editable in the dashboard at
# runtime; the env vars below are just defaults / the headless path.
# ─────────────────────────────────────────────────────────────────────────────

# `simulation` (default): Sentry/Vercel/push delivery and the LLM agents are
#   simulated; the deterministic verification gate (tests + error-gone check)
#   stays REAL. Runs fully offline.
# `live`: real adapters are used wherever the matching secret is present.
# Note: with no auth configured (see Clerk below) the app stays simulation-only
# regardless of this value, so a public guest demo can never reach real services.
WARDEN_MODE=simulation

# Postgres. Local dev points at the bundled Docker container (host port 5433).
# In production this is the Amazon Aurora PostgreSQL (Serverless v2) endpoint.
DATABASE_URL=postgres://warden:warden@localhost:5433/warden

# TLS for a managed Postgres like Aurora (leave blank for the local container):
#   PGSSLMODE=require
#   PGSSLROOTCERT=./certs/rds-global-bundle.pem   # verify against the RDS CA bundle
#   PGSSL_INSECURE=true                            # last resort: encrypt, skip verify
PGSSLMODE=
PGSSLROOTCERT=
PGSSL_INSECURE=

# ── auth (optional) ─────────────────────────────────────────────────────────
# Clerk. When CLERK_SECRET_KEY is set the dashboard requires sign-in and live
# mode unlocks. Leave both blank for the open, simulation-only guest demo.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── live-mode model providers (leave blank in simulation) ───────────────────
#
# AGENTS: any OpenAI-compatible provider (DeepSeek, GLM/Z.ai/Zhipu, OpenAI,
# OpenRouter, a local Ollama, etc.). These are PREFERRED over the native
# ANTHROPIC/OPENAI keys below. AGENT_* is the default for every agent;
# FIXER_*/REVIEWER_*/INVESTIGATOR_* override it (run the cross-check on two
# different model families). Requires WARDEN_MODE=live.
#
#   Cheapest: everything on GLM's FREE tier (glm-4.5-flash is free, no card):
#     AGENT_BASE_URL=https://api.z.ai/api/paas/v4
#     AGENT_API_KEY=<your z.ai key>
#     AGENT_MODEL=glm-4.5-flash
#
#   Two model families for the cross-check (Fixer=DeepSeek ~pennies, Reviewer=GLM free):
#     FIXER_BASE_URL=https://api.deepseek.com/v1
#     FIXER_API_KEY=<deepseek key>
#     FIXER_MODEL=deepseek-chat
#     REVIEWER_BASE_URL=https://api.z.ai/api/paas/v4
#     REVIEWER_API_KEY=<z.ai key>
#     REVIEWER_MODEL=glm-4.5-flash
AGENT_BASE_URL=
AGENT_API_KEY=
AGENT_MODEL=

# REVIEWER PANEL (PLAN §5.4): 1 Fixer + 1–3 Reviewers. More reviewers from
# DIFFERENT model families = a stronger decorrelated cross-check.
#   - Easiest: replicate the default reviewer provider N times (1–3):
#       REVIEW_PANEL_SIZE=3
#   - Or pick distinct providers per slot (run the cross-check on 3 families):
#       REVIEWER_1_BASE_URL=https://api.z.ai/api/paas/v4
#       REVIEWER_1_API_KEY=<z.ai key>
#       REVIEWER_1_MODEL=glm-4.5-flash
#       REVIEWER_2_BASE_URL=https://api.deepseek.com/v1
#       REVIEWER_2_API_KEY=<deepseek key>
#       REVIEWER_2_MODEL=deepseek-chat
#       # REVIEWER_3_* … (up to 3)
# Consensus: proceed only if all reviewers approve (default). Relax to a quorum:
#   REVIEW_APPROVALS_REQUIRED=2
REVIEW_PANEL_SIZE=
REVIEW_APPROVALS_REQUIRED=

# Native providers (used only if the OpenAI-compatible vars above are unset):
# Fixer/Investigator via the Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Reviewer via native OpenAI (chat-completions model; not a Codex/responses model)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Embeddings for incident memory (optional; falls back to deterministic local)
EMBEDDING_API_KEY=

# ── the repo Warden watches and fixes (the customer's app) ──────────────────
# In simulation this defaults to the bundled ./sample-app.
TARGET_REPO_PATH=./sample-app
# Live: the repo to clone and fix, as owner/name or a github.com URL. Leave
# blank to use the bundled sample app.
TARGET_REPO_URL=
# GitHub token (repo scope) so Warden can clone a private repo and open the PR
# that delivers a verified fix. Also settable in the dashboard (API Keys).
GITHUB_TOKEN=
# Identity for the fix commit. Use an email on the GitHub account so a delivered
# PR's Vercel/CI checks recognize the author. Defaults to a bot identity.
GIT_AUTHOR_EMAIL=
GIT_AUTHOR_NAME=

# ── delivery integrations (leave blank in simulation) ───────────────────────
# Sentry webhook signature verification
SENTRY_CLIENT_SECRET=
# Vercel deploy/rollback (the preview-promote delivery path)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_REPO_ID=

# ── API + cron auth (optional) ──────────────────────────────────────────────
# When set, approve/rollback/orchestrator-tick routes require
# `Authorization: Bearer <secret>`.
WARDEN_API_SECRET=
# Secret for the scheduled orchestrator-tick cron (e.g. Vercel Cron).
CRON_SECRET=

# ── web push (mobile approval notifications) ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:founder@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── operator settings (env defaults; all also editable in the dashboard) ────
# DELIVERY_MODE=pr           # how a verified fix ships: preview | pr | merge
# AUTO_APPROVE=false         # true = ship verified fixes without a human tap
# BILLING_MODE=managed       # managed (prepaid wallet) | byok (your own keys)
# FIX_MAX_ATTEMPTS=3         # re-proposals before escalating to a human (1–6)
# POLICY_MAX_FILES=5         # a fix touching more files than this escalates
# POLICY_MAX_CHURN=120       # max added+removed lines before a fix is "too large"
# POLICY_DENY_GLOBS=         # extra protected-path globs, one per line
# INSTALL_COMMAND=           # how to boot the target app for verification
# BUILD_COMMAND=
# RUN_COMMAND=
# SLACK_BOT_TOKEN=           # optional Slack approvals
# SLACK_SIGNING_SECRET=
# SLACK_CHANNEL=
