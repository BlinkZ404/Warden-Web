{
  "name": "warden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The on-call engineer you don't have. Catches production errors, fixes them, verifies the fix, and waits for one-tap human approval before anything ships.",
  "author": "Arifur Rahman Akash",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlinkZ404/Warden-Web.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "worker": "tsx scripts/worker.ts",
    "worker:watch": "tsx watch scripts/worker.ts",
    "demo": "tsx scripts/demo.ts",
    "setup": "npm run db:up && npm run migrate && npm run seed"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.7",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}
